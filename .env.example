# AkasGatha — Environment Variables
# Copy this file to .env and replace placeholder values with real values.
# NEVER commit .env to git.

# Application
APP_BASE_URL=http://localhost:3000

# ============================================================================
# AI PROVIDER CONFIGURATION
# ============================================================================
# Phase 4A: Use "mock" for development (no API key required)
# Phase 4B+: Use "gemini" or "openrouter" with real credentials
AI_PROVIDER=mock

# Optional: Specify model name (provider-specific)
JIGYASA_MODEL=

# Gemini API Key (required when AI_PROVIDER=gemini)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter Configuration (required when AI_PROVIDER=openrouter)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# ============================================================================
# REQUEST LIMITS
# ============================================================================
# Maximum characters in user question
JIGYASA_MAX_INPUT_CHARS=2000

# Maximum messages in conversation history
JIGYASA_MAX_HISTORY_MESSAGES=8

# Maximum total characters across all history messages
JIGYASA_MAX_HISTORY_CHARS=6000

# ============================================================================
# TIMEOUTS
# ============================================================================
# Request timeout in milliseconds
JIGYASA_REQUEST_TIMEOUT_MS=30000

# ============================================================================
# RATE LIMITING
# ============================================================================
# Maximum requests per time window
JIGYASA_RATE_LIMIT_REQUESTS=10

# Time window in seconds
JIGYASA_RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# LOGGING
# ============================================================================
# Log question content in development (true/false)
# SECURITY: Always set to false in production
JIGYASA_LOG_QUESTION_CONTENT=false
