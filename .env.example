# AkasGatha — Environment Variables
# Copy this file to .env.local and replace placeholder values with real values.
# NEVER commit .env.local to git.

# Application
APP_BASE_URL=http://localhost:3000

# ============================================================================
# AI PROVIDER CONFIGURATION
# ============================================================================
# Phase 4A: Use "mock" for development (no API key required)
# Phase 5: Use "groq" (recommended) or "gemini" with real credentials
AI_PROVIDER=mock

# Optional fallback provider (none or mock)
AI_FALLBACK_PROVIDER=none

# Groq Configuration (required when AI_PROVIDER=groq) - RECOMMENDED
# Get API key from: https://console.groq.com/keys
GROQ_API_KEY=
# Primary model (Gate 2: larger model for main requests)
GROQ_PRIMARY_MODEL=openai/gpt-oss-120b
# Secondary model (Gate 2: fallback for rate limits/failures)
GROQ_SECONDARY_MODEL=openai/gpt-oss-20b
# Legacy single model (used if PRIMARY not set)
GROQ_MODEL=openai/gpt-oss-20b
GROQ_TEMPERATURE=0.2
GROQ_MAX_OUTPUT_TOKENS=1800
GROQ_MAX_RETRIES=1

# Cerebras Configuration (currently DISABLED due to billing requirement)
# Status: Returns HTTP 402 Payment Required
# Keep configuration for future re-enablement
# Get API key from: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_TEMPERATURE=0.2
CEREBRAS_MAX_OUTPUT_TOKENS=1800
CEREBRAS_MAX_RETRIES=0
CEREBRAS_TIMEOUT_MS=30000
# CEREBRAS_VERSION_PATCH=2  # Optional: Set to 2 if API requires version header

# Cloudflare Workers AI Configuration (optional future fallback)
# Get from: https://dash.cloudflare.com/
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_MODEL=
CLOUDFLARE_TEMPERATURE=0.2
CLOUDFLARE_MAX_OUTPUT_TOKENS=1800
CLOUDFLARE_TIMEOUT_MS=30000
CLOUDFLARE_MAX_RETRIES=0

# Gemini Configuration (required when AI_PROVIDER=gemini)
# Get API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=1800
GEMINI_THINKING_LEVEL=low
GEMINI_MAX_RETRIES=1

# OpenRouter Configuration (optional future provider)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# ============================================================================
# REQUEST LIMITS
# ============================================================================
# Maximum characters in user question
JIGYASA_MAX_INPUT_CHARS=2000

# Maximum messages in conversation history
JIGYASA_MAX_HISTORY_MESSAGES=8

# Maximum total characters across all history messages
JIGYASA_MAX_HISTORY_CHARS=6000

# ============================================================================
# TIMEOUTS
# ============================================================================
# Request timeout in milliseconds
JIGYASA_REQUEST_TIMEOUT_MS=30000

# ============================================================================
# RATE LIMITING
# ============================================================================
# Maximum requests per time window
JIGYASA_RATE_LIMIT_REQUESTS=10

# Time window in seconds
JIGYASA_RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# LOGGING
# ============================================================================
# Log question content in development (true/false)
# SECURITY: Always set to false in production
JIGYASA_LOG_QUESTION_CONTENT=false

# ============================================================================
# RAG (RETRIEVAL-AUGMENTED GENERATION) CONFIGURATION
# ============================================================================
# Require RAG context for answers (true/false)
JIGYASA_REQUIRE_RAG=true

# Minimum RAG results required
JIGYASA_MIN_RAG_RESULTS=1

# Maximum characters in RAG context
JIGYASA_MAX_CONTEXT_CHARS=10000

# Enable streaming responses (true/false)
JIGYASA_STREAM_ENABLED=true

# Allow ungrounded general answers (true/false)
JIGYASA_ALLOW_UNGROUNDED_GENERAL_ANSWERS=false

# ============================================================================
# HYBRID KNOWLEDGE MODE (PHASE 5)
# ============================================================================
# Knowledge mode: "strict" (RAG only) or "hybrid" (RAG + general space knowledge)
JIGYASA_KNOWLEDGE_MODE=hybrid

# Allow general space/astronomy answers when corpus is insufficient (true/false)
JIGYASA_ALLOW_GENERAL_SPACE_ANSWERS=true

# Require RAG for all answers (overrides hybrid mode if true)
JIGYASA_REQUIRE_RAG_FOR_ALL_ANSWERS=false

# Require live verification for current/time-sensitive facts (true/false)
JIGYASA_REQUIRE_LIVE_VERIFICATION_FOR_CURRENT_FACTS=true

# ============================================================================
# LEGACY RAG CONFIGURATION (NOT REQUIRED FOR PHASE 5)
# ============================================================================
# Phase 4B uses local TF-IDF embeddings - no external API keys needed
# OpenAI and Pinecone are optional for future use only

# OpenAI API Key for embeddings (Phase 4B+)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Pinecone Configuration for vector storage (Phase 4B+)
# Get from: https://app.pinecone.io/
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=akashgatha-embeddings

# RAG Parameters
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
